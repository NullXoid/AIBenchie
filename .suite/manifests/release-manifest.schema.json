{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "product",
    "version",
    "source_commit",
    "source_provider",
    "source_repo",
    "aibenchie_report",
    "aibenchie_verdict",
    "artifacts",
    "sbom",
    "capability_policy_hash",
    "privacy_policy_hash",
    "nullbridge_registry_hash",
    "signed_by",
    "signed_at",
    "signature"
  ],
  "properties": {
    "product": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "source_commit": { "type": "string", "minLength": 7 },
    "source_provider": { "type": "string", "enum": ["forgejo", "gitea", "github", "gitlab", "custom_git"] },
    "source_repo": { "type": "string", "minLength": 1 },
    "aibenchie_report": { "type": "string", "minLength": 1 },
    "aibenchie_verdict": { "type": "string", "enum": ["pass", "ship_candidate"] },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "sha256"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
        }
      }
    },
    "sbom": {
      "type": "object",
      "required": ["name", "sha256"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" }
      }
    },
    "capability_policy_hash": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
    "privacy_policy_hash": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
    "nullbridge_registry_hash": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
    "signed_by": { "type": "string" },
    "signed_at": { "type": "string" },
    "signature": { "type": "string", "minLength": 1 }
  }
}
