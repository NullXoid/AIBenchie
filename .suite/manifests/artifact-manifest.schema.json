{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["artifacts"],
  "properties": {
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "sha256", "size_bytes"],
        "properties": {
          "name": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
          "size_bytes": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
