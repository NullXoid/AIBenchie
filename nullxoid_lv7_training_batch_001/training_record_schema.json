{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NullXoid Level 7-lite Training Record Schema",
  "type": "object",
  "required": [
    "schema_version",
    "record_type",
    "id",
    "scenario_id",
    "scenario_name",
    "risk_level",
    "prompt",
    "tool_scope_context",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "record_type": {
      "enum": [
        "sft_trajectory",
        "dpo_pair"
      ]
    },
    "id": {
      "type": "string"
    },
    "scenario_id": {
      "type": "string"
    },
    "scenario_name": {
      "type": "string"
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "prompt": {
      "type": "string"
    },
    "tool_scope_context": {
      "type": "object",
      "required": [
        "available_tools",
        "required_scopes",
        "blocked_scopes",
        "approval_required"
      ],
      "properties": {
        "available_tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_scopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocked_scopes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approval_required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "monologue_reasoning": {
      "type": "object",
      "required": [
        "mode",
        "summary",
        "risk_assessment",
        "authority_boundary",
        "next_safe_move"
      ],
      "properties": {
        "mode": {
          "enum": [
            "execute",
            "challenge",
            "clarify",
            "halt",
            "escalate"
          ]
        },
        "summary": {
          "type": "string"
        },
        "risk_assessment": {
          "type": "string"
        },
        "authority_boundary": {
          "type": "string"
        },
        "next_safe_move": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "trajectory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "step",
          "action",
          "observation",
          "expected_output"
        ],
        "properties": {
          "step": {
            "type": "integer"
          },
          "action": {
            "type": "string"
          },
          "observation": {
            "type": "string"
          },
          "expected_output": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "ideal_behavior": {
      "type": "object",
      "required": [
        "mode",
        "response"
      ],
      "properties": {
        "mode": {
          "enum": [
            "execute",
            "challenge",
            "clarify",
            "halt",
            "escalate"
          ]
        },
        "response": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "chosen": {
      "type": "string"
    },
    "rejected": {
      "type": "string"
    },
    "label": {
      "enum": [
        "challenge_behavior",
        "ambiguity_handling",
        "shutdown_compliance",
        "approval_behavior",
        "tool_scope",
        "observation_integrity"
      ]
    },
    "metadata": {
      "type": "object",
      "required": [
        "source",
        "created_at",
        "voice",
        "notes"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "voice": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "record_type": {
            "const": "sft_trajectory"
          }
        }
      },
      "then": {
        "required": [
          "monologue_reasoning",
          "trajectory",
          "ideal_behavior"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "record_type": {
            "const": "dpo_pair"
          }
        }
      },
      "then": {
        "required": [
          "chosen",
          "rejected",
          "label"
        ]
      }
    }
  ],
  "additionalProperties": false
}